{
  "map": {
    "id": "robocon_2026_cn_official_field",
    "name": "ROBOCON 2026 CN Official Field",
    "unit": "mm",
    "origin": {
      "x": 6000,
      "y": 12100
    },
    "axis_basis": {
      "x": [0, -1],
      "y": [1, 0]
    },
    "display_modes": {
      "mode_red": {
        "origin_offset": {
          "x": 0,
          "y": 0
        }
      },
      "mode_blue": {
        "origin_offset": {
          "x": 0,
          "y": 50
        }
      }
    },
    "default_mode": "mode_red",
    "axes": {
      "x_positive": "toward the negative direction of the current Y axis",
      "y_positive": "toward the positive direction of the current X axis"
    },
    "notes": "Based on the official ROBOCON 2026 CN atlas appendix pages 1-5. This file is a 2D top-view simplification of the official footprints. The base displayed coordinate origin is the current world point (6000, 12100). Display X points toward the negative direction of the current world Y axis, and display Y points toward the positive direction of the current world X axis. mode_red keeps this origin, and mode_blue moves the origin 50 mm along display Y positive. The 2025-09 atlas pages available in the workspace were cross-checked against the official robocon.org.cn notice published on 2026-01-07."
  },
